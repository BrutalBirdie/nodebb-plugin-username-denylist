{
  "id": "nodebb-plugin-username-denylist",
  "url": "https://github.com/brutalbirdie/nodebb-plugin-username-denylist",
  "library": "./library.js",
  "hooks": [
    { "hook": "static:app.load", "method": "init" },
    { "hook": "filter:admin.header.build", "method": "addAdminNavigation" },
    { "hook": "filter:register.check", "method": "checkUsername" }
  ],
  "staticDirs": { "static": "./static" },
  "templates": "static/templates",
  "languages": "languages",
  "modules": {
    "../admin/plugins/username-denylist.js": "./static/lib/admin.js"
  }
}
